{% extends 'base.html.twig' %}

{% block title %}Recherche · {{ query }}{% endblock %}

{% block body %}
<main style="padding-top: 80px;" class="container pb-5">

    <h1 class="section-title mt-4">
        Résultats pour <span class="highlight">"{{ query }}"</span>
    </h1>

    {% set total = projects|length + images|length %}

    {% if query == '' %}
        <p class="text-body-secondary">Saisis un mot-clé pour lancer la recherche.</p>

    {% elseif total == 0 %}
        <div class="text-center py-5">
            <p style="color: var(--megan-grey); font-size: 1.1rem;">
                Aucun résultat pour <strong>"{{ query }}"</strong>.<br>
                <small>Essaie un autre terme — genre, titre, ou nom de cosplay.</small>
            </p>
        </div>

    {% else %}

        {# ── PROJETS ──────────────────────────────────────────────── #}
        {% if projects is not empty %}
        <section class="mb-5">
            <h2 class="h4 mb-3" style="color: var(--megan-pink);">
                <i class="bi bi-disc me-2"></i>Projets ({{ projects|length }})
            </h2>
            <div class="row g-4">
                {% for project in projects %}
                <div class="col-sm-6 col-lg-4" data-aos="fade-up">
                    <div class="card bg-dark border-0 h-100 shadow-sm">
                        {% if project.image %}
                        <img src="{{ asset('images/' ~ project.image) }}"
                             class="card-img-top"
                             alt="{{ project.name }}"
                             style="height: 200px; object-fit: cover;">
                        {% endif %}
                        <div class="card-body">
                            <span class="badge mb-2" style="background: var(--megan-pink);">
                                {{ project.category.name }}
                            </span>
                            <h3 class="h5 text-white">{{ project.name }}</h3>
                            <p class="text-body-secondary small">{{ project.description }}</p>
                            <p class="text-body-secondary small">
                                {{ project.genre }} · {{ project.year }}
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-0">
                            <a href="{{ path('app_projet') }}"
                               class="btn btn-megan btn-sm w-100">Voir les projets</a>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {# ── IMAGES GALERIE ───────────────────────────────────────── #}
        {% if images is not empty %}
        <section>
            <h2 class="h4 mb-3" style="color: var(--megan-pink);">
                <i class="bi bi-image me-2"></i>Galerie ({{ images|length }})
            </h2>
            <div class="row g-3">
                {% for img in images %}
                <div class="col-6 col-md-4 col-lg-3" data-aos="zoom-in">
                    <div class="position-relative overflow-hidden rounded"
                         style="aspect-ratio: 1;">
                        <img src="{{ img.src }}"
                             alt="{{ img.alt }}"
                             class="w-100 h-100"
                             style="object-fit: cover;">
                        <div class="position-absolute bottom-0 start-0 end-0 p-2"
                             style="background: linear-gradient(transparent, rgba(0,0,0,.7));">
                            <small class="text-white">{{ img.alt }}</small><br>
                            <small style="color: var(--megan-pink);">{{ img.category }}</small>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </section>
        {% endif %}

    {% endif %}

</main>
{% endblock %}