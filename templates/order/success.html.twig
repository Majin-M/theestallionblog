{# ════════════════════════════════════════════════════
   templates/order/success.html.twig
   ════════════════════════════════════════════════════ #}
{% extends 'base.html.twig' %}
{% block title %}Commande confirmée · Megan Thee Stallion{% endblock %}

{% block body %}
<style>
    .success-section {
        background: radial-gradient(circle at top, #111, #000);
        min-height: 100vh;
        padding-top: 100px;
        display: flex;
        align-items: center;
    }

    .success-box {
        background: #111;
        border: 1px solid #1e1e1e;
        border-radius: 14px;
        padding: 3rem 2rem;
        text-align: center;
        max-width: 560px;
        margin: 0 auto;
    }

    .success-icon {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00c853, #00e676);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.2rem;
        margin: 0 auto 1.5rem;
        box-shadow: 0 0 30px rgba(0, 200, 83, 0.4);
    }

    .success-title {
        font-family: var(--font-headings);
        font-size: 2rem;
        color: white;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
    }

    .success-subtitle {
        color: #777;
        font-size: 0.9rem;
        margin-bottom: 2rem;
        line-height: 1.6;
    }

    .order-ref {
        background: #0a0a0a;
        border: 1px solid #1e1e1e;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 2rem;
        font-size: 0.8rem;
        color: #555;
    }

    .order-ref strong {
        color: var(--megan-pink);
        font-family: var(--font-headings);
        font-size: 1.1rem;
        display: block;
        margin-top: 4px;
    }

    /* Lignes du récapitulatif commande */
    .order-items-recap {
        text-align: left;
        margin-bottom: 1.5rem;
    }

    .recap-item {
        display: flex;
        justify-content: space-between;
        font-size: 0.82rem;
        color: #777;
        padding: 0.4rem 0;
        border-bottom: 1px solid #1a1a1a;
    }

    .recap-item:last-child { border-bottom: none; }

    .recap-total {
        display: flex;
        justify-content: space-between;
        font-size: 0.9rem;
        color: white;
        font-weight: 600;
        margin-top: 0.8rem;
    }

    .recap-total span:last-child {
        font-family: var(--font-headings);
        color: var(--megan-pink);
        font-size: 1.2rem;
    }
</style>

<section class="success-section">
    <div class="container">
        <div class="success-box" data-aos="fade-up">

            <div class="success-icon">✓</div>

            <h1 class="success-title">Merci !</h1>
            <p class="success-subtitle">
                Votre paiement a été confirmé.<br>
                Vous recevrez bientôt votre accès aux projets commandés.
            </p>

            {# Référence de commande #}
            <div class="order-ref">
                Référence de commande
                <strong>#{{ '%05d' | format(order.id) }}</strong>
            </div>

            {# Récapitulatif des articles commandés #}
            <div class="order-items-recap">
                {% for item in order.orderItems %}
                    <div class="recap-item">
                        <span>{{ item.project.name }} × {{ item.quantity }}</span>
                        <span>{{ item.lineTotalTTC | number_format(2, ',', ' ') }} €</span>
                    </div>
                {% endfor %}
                <div class="recap-total">
                    <span>Total payé</span>
                    <span>{{ order.total | number_format(2, ',', ' ') }} €</span>
                </div>
            </div>

            <a href="{{ path('app_projet') }}" class="btn btn-megan w-100">
                Découvrir d'autres projets
            </a>

        </div>
    </div>
</section>
{% endblock %}
