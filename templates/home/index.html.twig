    <!-- ── Scripts JS ── -->
    <script src="https://getbootstrap.com/docs/5.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        /**
         * Initialisation de la librairie AOS (Animate On Scroll).
         * Les animations se déclenchent une seule fois (once: true)
         * avec un décalage de 120px par rapport au bas du viewport.
         */
        AOS.init({
            duration: 900,
            easing: 'ease-out-cubic',
            once: true,
            offset: 120
        });

        /**
         * togglePlayer — Affiche ou masque un player Spotify embarqué.
         *
         * @param {string} id - L'identifiant de l'élément <div> contenant l'iframe.
         *
         * Utilisé dans les cards de la section HITS. L'iframe n'est pas chargée
         * tant que le bouton ▶ n'est pas cliqué, optimisant les performances initiales.
         *
         * @example
         * // HTML : <button onclick="togglePlayer('player-wap')">▶</button>
         * // Cache / affiche : <div id="player-wap" style="display:none;">...</div>
         */
        function togglePlayer(id) {
            const el = document.getElementById(id);
            if (!el) return;
            el.style.display = el.style.display === 'none' ? 'block' : 'none';
        }
    </script>

