                                    </svg>
                                    Twitter / X
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="https://www.tiktok.com/@theestallion" target="_blank" rel="noopener"
                                    class="social-link">
                                    <i class="bi bi-tiktok"></i> TikTok
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="https://www.facebook.com/MeganTheeStallion" target="_blank" rel="noopener"
                                    class="social-link">
                                    <i class="bi bi-facebook"></i> Facebook
                                </a>
                            </li>
