<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description"
        content="Site de présentation de Megan Thee Stallion — Albums, Hits et Collabs Internationales.">
    <meta name="author" content="Design basé sur Bootstrap">
    <title>Megan Thee Stallion · The H-Town Hottie</title>
    {% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;600;800&display=swap"
        rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link href="{{ asset('styles/app.css') }}" rel="stylesheet">
    {% endblock %}

    {% block javascripts %}
    <script src="https://getbootstrap.com/docs/5.3/assets/js/color-modes.js"></script>
    {% endblock %}

    <style>
        /* ════════════════════════════════════════════════════════════
           FIX MENU BURGER — Le menu collapse est rendu fixed
           pour rester accessible quelle que soit la position de scroll.
           La navbar mesure environ 56px, on positionne le menu juste en dessous.
           ════════════════════════════════════════════════════════════ */
        #navbarHeader {
            position: fixed;
            top: 56px;
            /* hauteur exacte de la navbar */
            left: 0;
            right: 0;
            z-index: 1029;
            /* juste sous la navbar (z-index: 1030) */
            max-height: calc(100vh - 56px);
            /* évite de dépasser l'écran */
            overflow-y: auto;
            /* scroll interne si le menu est très long */
        }

        /* ── Icône panier dans la navbar ── */
        .cart-btn {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            color: white;
            font-size: 1.1rem;
            text-decoration: none;
            transition: border-color 0.3s ease, background 0.3s ease;
        }

        .cart-btn:hover {
            border-color: var(--megan-pink);
            background: rgba(255, 0, 80, 0.1);
            color: white;
        }

        /* Badge rouge affichant le nombre d'articles */
        .cart-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: var(--megan-pink);
            color: white;
            font-size: 0.55rem;
            font-weight: 700;
            min-width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 3px;
            line-height: 1;
        }
    </style>
</head>

<body>
    <!-- ════════════════════════════════════════════════════════════
         HEADER — Navbar fixe + menu collapse
         ════════════════════════════════════════════════════════════ -->
    <header>
        <nav class="navbar navbar-dark bg-black shadow-sm fixed-top">
            <div class="container">

                {# ── Partie gauche : user + panier ── #}
                <div class="d-flex align-items-center gap-3">

                    {% if app.user %}

                    {# Dropdown utilisateur #}
                    <div class="dropdown">
                        <button class="btn btn-outline-light dropdown-toggle" type="button" data-bs-toggle="dropdown"
                            aria-expanded="false">
                            {{ app.user.firstname }}
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#">Mon profil</a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                    Déconnexion
                                </a>
                            </li>
                        </ul>
                    </div>

                    {# ── Icône panier (visible uniquement si connecté) ──
                    On lit le panier directement depuis la session Twig
                    pour afficher le nombre d'articles sans passer par le contrôleur. #}
                    {% set sessionCart = app.session.get('cart') ?? [] %}
                    {# On additionne toutes les quantités du panier #}
                    {% set cartCount = 0 %}
                    {% for qty in sessionCart %}
                    {% set cartCount = cartCount + qty %}
                    {% endfor %}

                    <a href="{{ path('app_cart_index') }}" class="cart-btn"
                        aria-label="Mon panier ({{ cartCount }} article{{ cartCount > 1 ? 's' : '' }})">
                        <i class="bi bi-bag"></i>
                        {% if cartCount > 0 %}
                        <span class="cart-badge">{{ cartCount }}</span>
                        {% endif %}
                    </a>

                    {% else %}

                    <a href="{{ path('app_login') }}" class="btn btn-outline-light">Connexion</a>
                    <a href="{{ path('app_register') }}" class="btn btn-megan">Inscription</a>

                    {% endif %}

                </div>

                {# Logo / Brand #}
                <a href="{{ path('app_home') }}" class="navbar-brand">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor"
                        class="bi bi-mic-fill" viewBox="0 0 16 16" style="color:var(--megan-pink)" aria-hidden="true">
                        <path d="M5 3a3 3 0 0 1 6 0v5a3 3 0 0 1-6 0V3z" />
                        <path
                            d="M3.5 6.5A.5.5 0 0 1 4 7v1a4 4 0 0 0 8 0V7a.5.5 0 0 1 1 0v1a5 5 0 0 1-4.5 4.975V15h3a.5.5 0 0 1 0 1h-7a.5.5 0 0 1 0-1h3v-2.025A5 5 0 0 1 3 8V7a.5.5 0 0 1 .5-.5z" />
                    </svg>
                    <span>Megan Thee Stallion</span>
                </a>

                {# ── Barre de recherche ── #}
                <form action="{{ path('app_search') }}" method="get"
                    class="d-flex align-items-center gap-2 mx-3 flex-grow-1" style="max-width: 340px;" role="search">
                    <div class="input-group input-group-sm">
                        <input type="search" name="q" value="{{ app.request.query.get('q') }}"
                            class="form-control bg-dark border-secondary text-white"
                            placeholder="Rechercher un projet, cosplay…" aria-label="Recherche" autocomplete="off">
                        <button class="btn btn-outline-secondary" type="submit" aria-label="Lancer la recherche">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                {# Burger #}
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarHeader"
                    aria-controls="navbarHeader" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

            </div>
        </nav>

        {# ── Menu collapse — maintenant fixed grâce au CSS ci-dessus ──
        Il apparaît juste sous la navbar quelle que soit la position de scroll. #}
        <div class="collapse text-bg-dark" id="navbarHeader">
            <div class="container py-4">
                <div class="row">

                    {# ── Colonne 1 : Navigation ── #}
                    <div class="col-sm-5 col-md-4">
                        <h4 class="text-white mb-3">Navigation</h4>
                        <nav aria-label="Sections de la page">
                            <ul class="list-unstyled mb-0" style="line-height: 2.2rem;">
                                <li><a href="#parcours" class="nav-anchor"><span class="nav-anchor-icon">01</span> Son
                                        Parcours</a></li>
                                <li><a href="{{ path('app_projet') }}" class="nav-anchor"><span
                                            class="nav-anchor-icon">02</span> Projets</a></li>
                                <li><a href="#tour" class="nav-anchor"><span class="nav-anchor-icon">03</span> Tour
                                        Dates</a></li>
                                <li><a href="#collabs" class="nav-anchor"><span class="nav-anchor-icon">04</span>
                                        Collaborations</a></li>
                                <li><a href="#impact" class="nav-anchor"><span class="nav-anchor-icon">05</span> Her
                                        Impact</a></li>
                                <li><a href="{{ path('app_galerie') }}" class="nav-anchor"><span
                                            class="nav-anchor-icon">06</span> Galerie</a></li>

                            </ul>
                        </nav>
                    </div>

                    {# ── Colonne 2 : À propos ── #}
                    <div class="col-sm-4 col-md-4 py-4 py-sm-0">
                        <h4 class="text-white mb-3">À propos</h4>
                        <p class="text-body-secondary" style="font-size: 0.9rem; line-height: 1.6;">
                            Megan Jovon Ruth Pete, connue sous le nom de Megan Thee Stallion,
                            est une rappeuse, auteure-compositrice et entrepreneuse américaine
                            originaire de Houston, Texas.
                        </p>
                    </div>

                    {# ── Colonne 3 : Réseaux sociaux ── #}
                    <div class="col-sm-3 col-md-4 py-4 py-sm-0">
                        <h4 class="text-white mb-3">Réseaux</h4>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <a href="https://www.instagram.com/theestallion/" target="_blank" rel="noopener"
                                    class="social-link">
                                    <i class="bi bi-instagram"></i> Instagram
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="https://twitter.com/theestallion" target="_blank" rel="noopener"
                                    class="social-link">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
