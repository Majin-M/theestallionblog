            </div>

            {# ── Single : Cobra ── #}
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="400">
                <div class="hit-card small">
                    <img src="https://cdn-images.dzcdn.net/images/cover/9505faa33b12e44f9afc3e57def6b9f0/0x1900-000000-80-0-0.jpg"
                        alt="Cobra">
                    <div class="hit-overlay">
                        <h3>Cobra</h3>
                        <div id="player-cobra" style="display:none;">
                            <iframe style="border-radius:12px; margin-top:10px"
                                src="https://open.spotify.com/embed/track/3Kh8X9lHztqVBTgw30HbXn?utm_source=generator"
                                width="100%" height="80" frameborder="0" allow="autoplay; encrypted-media"
                                loading="lazy" title="Cobra sur Spotify"></iframe>
                        </div>
                        <span>Chart Top 1 Hit</span>
                        <button onclick="togglePlayer('player-cobra')" class="play-btn"
                            aria-label="Écouter Cobra">▶</button>
                    </div>
                </div>
            </div>

            {# ── Single : Boa (GIF cover) ── #}
            <div class="col-md-4" data-aos="fade-left" data-aos-delay="500">
                <div class="hit-card small">
                    <img src="https://images.genius.com/eda0923e5cd9d217a88332a70ece4a90.600x600x165.gif" alt="Boa"
                        style="object-fit:cover; width:100%; height:100%;">
                    <div class="hit-overlay">
                        <h3>Boa</h3>
                        <div id="player-boa" style="display:none;">
                            <iframe style="border-radius:12px; margin-top:10px"
                                src="https://open.spotify.com/embed/track/3tUwmCcdunuXKwHu8u2aBn?utm_source=generator"
                                width="100%" height="80" frameborder="0" allow="autoplay; encrypted-media"
                                loading="lazy" title="Boa sur Spotify"></iframe>
                        </div>
