                    </div>
                </div>
            </div>

            {# ── Single : Anxiety ── #}
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="600">
                <div class="hit-card">
                    <img src="https://cdn-images.dzcdn.net/images/cover/e77b162b10e0d0c07e2810269750ecdf/1900x1900-000000-80-0-0.jpg"
                        alt="Anxiety">
                    <div class="hit-overlay">
                        <h3>Anxiety</h3>
                        <div id="player-anxiety" style="display:none;">
                            <iframe style="border-radius:12px; margin-top:10px"
                                src="https://open.spotify.com/embed/track/6Ve9MNsl8OFg6rHd227bYh?utm_source=generator"
                                width="100%" height="80" frameborder="0" allow="autoplay; encrypted-media"
                                loading="lazy" title="Anxiety sur Spotify"></iframe>
                        </div>
                        <span>Deep Cut. Emotional.</span>
                        <button onclick="togglePlayer('player-anxiety')" class="play-btn"
                            aria-label="Écouter Anxiety">▶</button>
                    </div>
                </div>
            </div>

            {# ── Single : Captain Hook ── #}
            <div class="col-md-4" data-aos="fade-up" data-aos-delay="700">
                <div class="hit-card">
                    <img src="https://i1.sndcdn.com/artworks-dFgwX7t7Im5D11A1-QEzIqA-t1080x1080.jpg" alt="Captain Hook">
                    <div class="hit-overlay">
                        <h3>Captain Hook</h3>
                        <div id="player-hook" style="display:none;">
                            <iframe style="border-radius:12px; margin-top:10px"
                                src="https://open.spotify.com/embed/track/4R2kfaDFGUsAtJQx0RgMOo?utm_source=generator"
                                width="100%" height="80" frameborder="0" allow="autoplay; encrypted-media"
                                loading="lazy" title="Captain Hook sur Spotify"></iframe>
                        </div>
                        <span>Viral Flow</span>
                        <button onclick="togglePlayer('player-hook')" class="play-btn"
                            aria-label="Écouter Captain Hook">▶</button>
                    </div>
                </div>
            </div>

        </div>{# /.row — hits #}
    </div>
</section>

{% endblock %}